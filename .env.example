# Ligação à base de dados PostgreSQL (obrigatório).
DATABASE_URL=postgres://user:password@localhost:5432/gestcondo

# Segredo usado pelo better-auth para assinar sessões/tokens (obrigatório).
# Gerar um valor aleatório longo, ex.: openssl rand -base64 32
BETTER_AUTH_SECRET=

# URL pública onde a aplicação corre (obrigatório fora do localhost, para
# os links de verificação de email / reset de password ficarem corretos).
# Em desenvolvimento local pode deixar-se por definir (assume localhost).
BETTER_AUTH_URL=http://localhost:3000

# Envio de email transacional (verificação de email, reset de password) via
# a API REST do Resend (https://resend.com). Opcional: sem esta chave, os
# emails não são enviados — o conteúdo fica registado na consola do
# servidor, o que é suficiente para testar os fluxos em desenvolvimento
# local (ver lib/email.ts).
RESEND_API_KEY=
EMAIL_FROM="GestCondo <onboarding@resend.dev>"

# Armazenamento de ficheiros (documentos, fotos de ocorrências, apólices de
# seguro) via Vercel Blob. Obrigatório para o upload funcionar — ao
# contrário do email, não há modo local sem esta chave (ver lib/storage.ts).
# Obter em: dashboard da Vercel → Storage → criar um Blob store → Token.
BLOB_READ_WRITE_TOKEN=
